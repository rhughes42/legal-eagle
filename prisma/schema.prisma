// Prisma Database Schema for the Legal Document Management System
// PostgreSQL database with AI-extracted metadata for legal documents

// Dataabase config defaults to port 5432 for PostgreSQL
datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

/**
 * The Document model represents legal documents uploaded to the system.
 * It includes fields for both extracted metadata and AI-generated insights.
 */
model Document {
    id         Int       @id @default(autoincrement())
    fileName   String // Original uploaded filename
    title      String? // [Extracted] Document title
    date       DateTime? // [Extracted] Document date (filing, judgment, etc.)
    court      String? // [Extracted] Court or jurisdiction
    caseNumber String? // [Extracted] Case or docket number
    summary    String? // [Generated] Document summary

    // [Generated] High-level classification
    caseType String? // e.g., civil, criminal, family, intellectual property
    area     String? // e.g., employment, intellectual property, contracts, family law, criminal law

    // [Generated] Area-specific details (flexible key/value JSON data, e.g., compensation, patentNumber, costs, debtAmount)
    areaData Json?

    metadata  Json? // [Generated] Additional AI-extracted metadata
    createdAt DateTime @default(now()) // Record creation timestamp
    updatedAt DateTime @updatedAt // Record update timestamp

    // Relationships and analytics
    segments      DocumentSegment[]
    embeddings    DocumentEmbedding[]
    outgoingLinks DocumentRelation[] @relation("RelationSource")
    incomingLinks DocumentRelation[] @relation("RelationTarget")
}

/// Segmented portions of a document used for partial enrichment and analytics.
model DocumentSegment {
    id         Int      @id @default(autoincrement())
    document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
    documentId Int
    title      String?
    content    String
    tokenCount Int?
    position   Int      // Stable ordering of segments within the document
    createdAt  DateTime @default(now())

    @@index([documentId, position])
}

/// Persisted embeddings for similarity search and cross-linking.
model DocumentEmbedding {
    id         Int      @id @default(autoincrement())
    document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
    documentId Int
    model      String?
    embedding  Json?   // Numeric vector stored as JSON to keep Postgres portable
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([documentId])
}

/// Graph of relationships between documents (citations, references, precedents).
model DocumentRelation {
    id           Int      @id @default(autoincrement())
    source       Document @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
    sourceId     Int
    target       Document @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)
    targetId     Int
    relationType String
    description  String?
    createdAt    DateTime @default(now())

    @@index([sourceId])
    @@index([targetId])
}
