# Database Configuration
# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Developer Note: Advise to keep 127.0.0.1 contra localhost so it's found reliably
DATABASE_URL=postgresql://postgres:changeme@127.0.0.1:5432/legal_eagle

# PostgreSQL container credentials (used by docker-compose)
# POSTGRES_PASSWORD is required and must be set to a strong value before running docker compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=legal_eagle

# OpenAI API Configuration (Optional)
# Required for AI-powered metadata extraction from uploaded documents
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Model Configuration (Optional)
# Override the default chat model used for document metadata extraction
# Default: gpt-5-mini
OPENAI_CHAT_MODEL=gpt-5-mini

# Optional legacy fallback variable still supported by the app
# MODEL_PRIMARY will be used only if OPENAI_CHAT_MODEL is not set
MODEL_PRIMARY=gpt-5-mini

# Application Environment
# Options: development, production, test
NODE_ENV=development

# Application Port (Optional)
# Default: 3000
PORT=3000

# CORS Configuration (Optional)
# Comma-separated list of allowed origins for CORS requests.
# Leave empty to disable CORS (recommended for production behind a reverse proxy).
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=
